# Enforce LF line endings for all text files
* text=auto eol=lf

# Windows batch/PowerShell files need CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets — never touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.tga binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.ico binary
*.zip binary
*.obj binary
*.lib binary
*.dll binary
*.exe binary
*.pdb binary
*.a binary
*.so binary
*.dylib binary
